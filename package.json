{
  "name": "cfyl-web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest run",
    "assign:teams": "ts-node scripts/assign-teams-to-divisions.ts",
    "import:staffs": "ts-node scripts/import-staffs-from-xlsx.ts",
    "verify:tournament-foundation": "ts-node -P scripts/tournament-v2/tsconfig.verify.json scripts/tournament-v2/verify-foundation.ts",
    "bootstrap:tournament-super-admin": "ts-node -P scripts/tournament-v2/tsconfig.verify.json scripts/tournament-v2/bootstrap-super-admin.ts",
    "seed:tournament-phase2": "ts-node -P scripts/tournament-v2/tsconfig.verify.json scripts/tournament-v2/seed-phase2-core-domain.ts",
    "verify:tournament-phase2-crud": "ts-node -P scripts/tournament-v2/tsconfig.verify.json scripts/tournament-v2/verify-phase2-crud.ts",
    "verify:tournament-schedule-import-runtime": "ts-node -P scripts/tournament-v2/tsconfig.verify.json scripts/tournament-v2/verify-schedule-import-runtime.ts",
    "verify:tournament-qualification-draw-runtime": "ts-node -r ./scripts/tournament-v2/register-path-alias.js -P scripts/tournament-v2/tsconfig.verify.json scripts/tournament-v2/verify-qualification-draw-runtime.ts",
    "verify:tournament-quick-result-runtime": "ts-node -r ./scripts/tournament-v2/register-path-alias.js -P scripts/tournament-v2/tsconfig.verify.json scripts/tournament-v2/verify-quick-result-runtime.ts",
    "verify:tournament-standings-override-runtime": "ts-node -r ./scripts/tournament-v2/register-path-alias.js -P scripts/tournament-v2/tsconfig.verify.json scripts/tournament-v2/verify-standings-override-runtime.ts",
    "verify:tournament-full-report-runtime": "ts-node -r ./scripts/tournament-v2/register-path-alias.js -P scripts/tournament-v2/tsconfig.verify.json scripts/tournament-v2/verify-full-report-runtime.ts"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.108.2",
    "dotenv": "^17.4.2",
    "exceljs": "^4.4.0",
    "next": "16.2.9",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "tailwindcss": "^4",
    "ts-node": "^10.9.2",
    "typescript": "^5",
    "vitest": "^4.1.10"
  }
}
